cat > .gitignore <<'EOF'
# Frontend dependencies
frontend/node_modules/

# Frontend build output
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/

# Backend virtual environments
backend/.venv/
backend/venv/
backend/env/

# Backend runtime files
backend/uploads/
backend/outputs/

# AI models / large files
backend/best.pt
*.pt
*.pth
*.onnx

# GeoTIFF / dataset files
*.tif
*.tiff
dataset/
datasets/
data/

# Environment files
.env
.env.*
frontend/.env
frontend/.env.*
backend/.env
backend/.env.*

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS / Editor
.DS_Store
.vscode/
.idea/

# Vercel
.vercel/
frontend/.vercel/

# TypeScript
*.tsbuildinfo
frontend/next-env.d.ts
EOF